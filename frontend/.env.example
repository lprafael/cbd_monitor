# URL de la API del backend (se usa en build y en npm start)
# Desarrollo local con backend en tu PC:
#   REACT_APP_API_URL=http://localhost:8000
# Pruebas contra servidor (Docker backend en 5001):
REACT_APP_API_URL=http://172.16.222.222:5001

# Base path cuando la app se sirve en un subpath (ej. https://sistemas.mopc.gov.py/cbd_monitor/)
# También se define "homepage": "/cbd_monitor" en package.json para el build.
# PUBLIC_URL=/cbd_monitor
