# Copiar a .env y ajustar valores. No subir .env a git.
# Este compose levanta el servidor Postgres; el "host" lo usan los clientes (ej. cbd_monitor).

POSTGRES_USER=cbd_auth
POSTGRES_PASSWORD=tu_password_seguro
POSTGRES_DB=cbd_auth
# Puerto en el host (5433 para no chocar con otro Postgres)
POSTGRES_PORT=5433
# Host donde los clientes conectarán (solo referencia; en cbd_monitor usar AUTH_DB_HOST=172.16.222.222 o la IP del servidor)
# AUTH_SERVICE_HOST=172.16.222.222
