# Configuración de Base de Datos PostgreSQL (datos CBD, reportes)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=tu_base_de_datos
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña

# Base de datos de autenticación (Postgres local, opción A - postgres-auth)
AUTH_DB_HOST=172.16.222.222
AUTH_DB_PORT=5433
AUTH_DB_NAME=cbd_auth
AUTH_DB_USER=cbd_auth
AUTH_DB_PASSWORD=tu_password_postgres_auth

# URL de la API para el frontend (debe ser accesible desde el navegador)
REACT_APP_API_URL=http://172.16.222.222:5001

# Email (para generar_excel_cbd_objetivo.py --verificacion y --notificacion)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_email@gmail.com
EMAIL_PASSWORD=tu_contraseña_aplicacion
EMAIL_FROM=tu_email@gmail.com
EMAIL_DIRECTOR=director@ejemplo.com
